{
  "name": "@mterminal/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply mterminal --local",
    "migrate:remote": "wrangler d1 migrations apply mterminal --remote",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mterminal/manifest-validator": "workspace:*",
    "@mterminal/marketplace-types": "workspace:*",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "fflate": "^0.8.2",
    "hono": "^4.6.10"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.32",
    "@cloudflare/workers-types": "^4.20241112.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "wrangler": "^3.86.0"
  }
}
